@model MvcApp.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Sign In — Manfoods McDonald's</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        @@keyframes cardEntrance { 0%{opacity:0;transform:translateY(28px) scale(.97)} 100%{opacity:1;transform:translateY(0) scale(1)} }
        @@keyframes logoFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
        @@keyframes shimmer { 0%{background-position:-400px 0} 100%{background-position:400px 0} }
        @@keyframes floatUp { 0%{transform:translateY(0) rotate(0deg);opacity:.25} 100%{transform:translateY(-100vh) rotate(360deg);opacity:0} }

        .login-body {
            background: linear-gradient(150deg, #27251f 0%, #1e1c18 50%, #0f0e0b 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            position: relative; overflow: hidden;
        }
        .login-body::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
            background: #ffbc0d;
        }

        /* Floating orbs */
        .bubble { position: absolute; border-radius: 50%; background: rgba(255,188,13,.1); animation: floatUp linear infinite; }

        .login-container { width: 100%; max-width: 420px; padding: 16px; position: relative; z-index: 10; }

        .login-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 44px 40px 36px;
            box-shadow: 0 8px 32px rgba(0,0,0,.3);
            animation: cardEntrance .55s cubic-bezier(.22,1,.36,1) both;
        }

        .logo-wrap {
            display: inline-block;
            animation: logoFloat 3.5s ease-in-out infinite;
            filter: drop-shadow(0 4px 12px rgba(255,188,13,.4));
            margin-bottom: 14px;
        }
        .logo-wrap img { width: 72px; height: auto; }

        .login-title { font-size: 28px; font-weight: 700; color: #292929; margin: 0; line-height: 32px; letter-spacing: -.15px; }
        .login-title span { color: #ffbc0d; }
        .login-subtitle { font-size: 11px; color: #9a9490; margin: 6px 0 0; letter-spacing: 1.2px; text-transform: uppercase; font-weight: 400; }

        .divider { display: flex; align-items: center; gap: 10px; margin: 22px 0 18px; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #e5e7eb; }
        .divider span { font-size: 11px; color: #bbb; font-weight: 400; white-space: nowrap; }

        .field-wrap { position: relative; margin-bottom: 16px; }
        .field-wrap .fi { position: absolute; left: 14px; top: calc(50% + 13px); transform: translateY(-50%); color: #ccc; font-size: 15px; pointer-events: none; transition: color .2s; }
        .field-wrap:focus-within .fi { color: #c08b00; }
        .field-wrap label { font-size: 11px; font-weight: 700; color: #6b6b6b; text-transform: uppercase; letter-spacing: .8px; margin-bottom: 6px; display: block; }
        .field-wrap input {
            padding-left: 40px; height: 48px; font-size: 15px;
            border-radius: 8px; border: 1.5px solid #e5e7eb;
            background: #fafafa; color: #292929; width: 100%;
            transition: all .2s; outline: none;
            font-family: 'Speedee', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        .field-wrap input:focus { background: #fff; border-color: #ffbc0d; box-shadow: 0 0 0 3px rgba(255,188,13,.2); }
        .field-wrap input::placeholder { color: #ccc; }

        .btn-signin {
            width: 100%; min-height: 50px;
            background-color: #ffbc0d; border: 1px solid #c08b00;
            border-radius: 48px; color: #292929;
            font-size: 16px; font-weight: 700; cursor: pointer;
            transition: background .15s, box-shadow .15s, transform .1s;
            margin-top: 8px;
            font-family: 'Speedee', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        .btn-signin:hover { background-color: #e6a800; box-shadow: 0 4px 14px rgba(255,188,13,.4); transform: translateY(-1px); }

        .admin-link { display: block; text-align: center; margin-top: 16px; font-size: 12px; color: #bbb; }
        .admin-link a { color: #c08b00; font-weight: 700; text-decoration: none; }
        .admin-link a:hover { text-decoration: underline; }
        .login-footer { text-align: center; margin-top: 18px; font-size: 11px; color: #ccc; }

        .alert-error-banner { background: #fff5f5; border-left: 4px solid #c8102e; color: #c8102e; padding: 11px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 16px; }
    </style>
</head>
<body class="login-body">

    <div class="bubble" style="width:60px;height:60px;left:8%;animation-duration:13s;bottom:-60px;"></div>
    <div class="bubble" style="width:30px;height:30px;left:22%;animation-duration:9s;animation-delay:2s;bottom:-30px;"></div>
    <div class="bubble" style="width:80px;height:80px;left:72%;animation-duration:16s;animation-delay:1s;bottom:-80px;"></div>
    <div class="bubble" style="width:18px;height:18px;left:87%;animation-duration:8s;animation-delay:3s;bottom:-18px;"></div>
    <div class="bubble" style="width:50px;height:50px;left:50%;animation-duration:12s;animation-delay:.5s;bottom:-50px;"></div>

    <div class="login-container">
        <div class="login-card">
            <div class="text-center">
                <div class="logo-wrap">
                    <img src="/images/mclogo.png" alt="Logo"/>
                </div>
                <h1 class="login-title">Manfoods <span>McDonald's</span></h1>
                <p class="login-subtitle">Workforce Analytics Platform</p>
            </div>

            <div class="divider"><span>Sign in to continue</span></div>

            <form asp-area="Home" asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-error-banner">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="bi bi-exclamation-triangle-fill me-1"></i>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="field-wrap">
                    <label>Email Address</label>
                    <i class="bi bi-envelope-fill fi"></i>
                    <input asp-for="Email" type="email" placeholder="you@manfoods.com" autocomplete="email"/>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="field-wrap">
                    <label>Password</label>
                    <i class="bi bi-lock-fill fi"></i>
                    <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password"/>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-signin">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="admin-link">
                Admin? <a href="/admin/account/login">Go to Admin Portal →</a>
            </div>
            <div class="login-footer">&copy; @DateTime.Now.Year Manfoods McDonald's — All rights reserved</div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
