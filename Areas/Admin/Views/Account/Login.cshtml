@model MvcApp.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Admin Sign In — Manfoods McDonald's</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        @@keyframes cardEntrance { 0%{opacity:0;transform:translateY(40px) scale(.96)} 100%{opacity:1;transform:translateY(0) scale(1)} }
        @@keyframes logoFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
        @@keyframes shimmer { 0%{background-position:-400px 0} 100%{background-position:400px 0} }
        @@keyframes floatUp { 0%{transform:translateY(0) rotate(0deg);opacity:.5} 100%{transform:translateY(-100vh) rotate(360deg);opacity:0} }

        .login-body {
            background: linear-gradient(145deg, #1a0a00 0%, #3d0d00 40%, #DA291C 80%, #b82015 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            position: relative; overflow: hidden;
        }
        .login-body::before {
            content:''; position:absolute; top:0; left:0; right:0; height:4px;
            background:linear-gradient(90deg,#FFC72C,#ffdb6e,#FFC72C);
            background-size:200% 100%; animation:shimmer 2.5s linear infinite;
        }
        .bubble { position:absolute; border-radius:50%; background:rgba(255,199,44,.12); animation:floatUp linear infinite; }
        .login-container { width:100%; max-width:420px; padding:16px; position:relative; z-index:10; }
        .login-card {
            background:rgba(255,255,255,.97); border-radius:24px; padding:44px 40px 36px;
            box-shadow:0 20px 60px rgba(0,0,0,.4), 0 2px 8px rgba(0,0,0,.2);
            animation:cardEntrance .6s cubic-bezier(.22,1,.36,1) both;
            border-top:3px solid #DA291C;
        }
        .admin-badge {
            display:inline-flex; align-items:center; gap:5px;
            background:#fff3f3; border:1px solid #ffd5d2; color:#DA291C;
            font-size:10px; font-weight:800; letter-spacing:.8px; text-transform:uppercase;
            padding:3px 10px; border-radius:20px; margin-bottom:12px;
        }
        .logo-wrap { display:inline-block; animation:logoFloat 3s ease-in-out infinite; filter:drop-shadow(0 4px 10px rgba(218,41,28,.3)); }
        .login-title { font-size:22px; font-weight:900; color:#27251F; margin:10px 0 0; }
        .login-title span { color:#DA291C; }
        .login-subtitle { font-size:12px; color:#9a9490; margin:4px 0 0; letter-spacing:1px; text-transform:uppercase; font-weight:500; }
        .divider { display:flex; align-items:center; gap:10px; margin:18px 0; }
        .divider::before,.divider::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,transparent,#e8e8e8,transparent); }
        .divider span { font-size:11px; color:#bbb; font-weight:600; letter-spacing:.5px; }
        .field-wrap { position:relative; margin-bottom:16px; }
        .field-wrap .fi { position:absolute; left:14px; top:calc(50% + 13px); transform:translateY(-50%); color:#ccc; font-size:15px; pointer-events:none; transition:color .2s; }
        .field-wrap:focus-within .fi { color:#DA291C; }
        .field-wrap label { font-size:11px; font-weight:700; color:#7a7672; text-transform:uppercase; letter-spacing:.6px; margin-bottom:5px; display:block; }
        .field-wrap input { padding-left:40px; height:48px; font-size:14px; border-radius:12px; border:1.5px solid #eee; background:#fafafa; color:#27251F; width:100%; transition:all .2s; }
        .field-wrap input:focus { background:#fff; border-color:#DA291C; box-shadow:0 0 0 3px rgba(218,41,28,.1); outline:none; }
        .field-wrap input::placeholder { color:#ccc; }
        .btn-signin { width:100%; height:50px; background:linear-gradient(135deg,#DA291C,#c0200f); border:none; border-radius:12px; color:#fff; font-size:15px; font-weight:700; cursor:pointer; transition:all .2s; box-shadow:0 4px 14px rgba(218,41,28,.4); margin-top:8px; position:relative; overflow:hidden; }
        .btn-signin::before { content:''; position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent); transition:left .4s; }
        .btn-signin:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(218,41,28,.5); }
        .btn-signin:hover::before { left:100%; }
        .alert-banner { border-radius:10px; margin-bottom:16px; }
        .login-footer { text-align:center; margin-top:20px; font-size:11px; color:#bbb; }
        .user-portal-link { display:block; text-align:center; margin-top:14px; font-size:12px; color:#bbb; }
        .user-portal-link a { color:#DA291C; font-weight:600; text-decoration:none; }
        .user-portal-link a:hover { text-decoration:underline; }
    </style>
</head>
<body class="login-body">
    <div class="bubble" style="width:70px;height:70px;left:5%;animation-duration:14s;bottom:-70px;"></div>
    <div class="bubble" style="width:30px;height:30px;left:18%;animation-duration:9s;animation-delay:2s;bottom:-30px;"></div>
    <div class="bubble" style="width:90px;height:90px;left:75%;animation-duration:16s;animation-delay:1s;bottom:-90px;"></div>
    <div class="bubble" style="width:20px;height:20px;left:88%;animation-duration:8s;animation-delay:3s;bottom:-20px;"></div>

    <div class="login-container">
        <div class="login-card">
            <div class="text-center">
                <div class="admin-badge"><i class="bi bi-shield-lock-fill"></i> Admin Portal</div>
                <div class="logo-wrap">
                    <img src="/images/mclogo.png" alt="Logo" style="width:70px;height:auto;"/>
                </div>
                <h1 class="login-title">Manfoods <span>McDonald's</span></h1>
                <p class="login-subtitle">Admin Dashboard</p>
            </div>

            <div class="divider"><span>Sign in to continue</span></div>

            <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-banner alert-error-banner mb-3">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="bi bi-exclamation-triangle-fill me-1"></i>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="field-wrap">
                    <label>Email Address</label>
                    <i class="bi bi-envelope-fill fi"></i>
                    <input asp-for="Email" type="email" placeholder="admin@manfoods.com" autocomplete="email"/>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="field-wrap">
                    <label>Password</label>
                    <i class="bi bi-lock-fill fi"></i>
                    <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password"/>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-signin">
                    <i class="bi bi-shield-lock me-2"></i>Sign In as Admin
                </button>
            </form>

            <div class="user-portal-link">
                Not an admin? <a href="/home/account/login">Go to User Portal →</a>
            </div>
            <div class="login-footer">&copy; @DateTime.Now.Year Manfoods McDonald's</div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
