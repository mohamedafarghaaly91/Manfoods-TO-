@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpCtx
@{
    var session = HttpCtx.HttpContext?.Session;
    var userEmail = session?.GetString("Email") ?? "";
    var userRole  = session?.GetString("Role")  ?? "";
    var currentPath = HttpCtx.HttpContext?.Request.Path.Value ?? "";
    bool IsActive(string seg) => currentPath.Contains(seg, StringComparison.OrdinalIgnoreCase);
    var initials = string.IsNullOrEmpty(userEmail) ? "A" : userEmail.Substring(0,1).ToUpper();
    bool isFullAdmin = userRole == "Admin_Full";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Admin | Manfoods" : "Admin | Manfoods McDonald's")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>
<body>
<div class="app-wrapper">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo-row">
                <img src="/images/mclogo.png" alt="Logo" class="brand-logo-img"/>
                <div class="brand-texts">
                    <span class="brand-name-main">Manfoods</span>
                    <span class="brand-name-sub">Admin Portal</span>
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Analytics</div>
            <a href="/admin/dashboard/analytics" class="nav-item @(IsActive("Analytics") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-bar-chart-line-fill"></i></span>
                    <span class="nav-item-label">Global Analytics</span>
                </span>
            </a>
            <a href="/admin/dashboard/turnover" class="nav-item @(IsActive("Turnover") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-pie-chart-fill"></i></span>
                    <span class="nav-item-label">Turnover Analysis</span>
                </span>
            </a>

            <div class="nav-section-label">Management</div>
            <a href="/admin/dashboard/uploads" class="nav-item @(IsActive("Uploads") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-cloud-upload-fill"></i></span>
                    <span class="nav-item-label">Data Management</span>
                </span>
            </a>
            <a href="/admin/dashboard/reports" class="nav-item @(IsActive("Reports") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-file-earmark-bar-graph-fill"></i></span>
                    <span class="nav-item-label">Reports</span>
                </span>
            </a>

            @if (isFullAdmin)
            {
                <div class="nav-section-label">System</div>
                <a href="/admin/dashboard/users" class="nav-item @(IsActive("Users") ? "active" : "")">
                    <span class="nav-item-inner">
                        <span class="nav-icon-wrap"><i class="bi bi-people-fill"></i></span>
                        <span class="nav-item-label">Users</span>
                        <span class="nav-item-badge">Admin</span>
                    </span>
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-footer-inner">
                <div class="user-avatar">@initials</div>
                <div class="user-details">
                    <div class="user-email">@userEmail</div>
                    <div class="user-role-badge">
                        <i class="bi bi-shield-fill-check" style="font-size:9px;"></i>
                        @userRole.Replace("_"," ")
                    </div>
                </div>
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" title="Sign Out"><i class="bi bi-box-arrow-right"></i></button>
                </form>
            </div>
        </div>
    </aside>

    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert-banner alert-success-banner">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-banner alert-error-banner">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            </div>
        }
        <div class="page-content">
            @RenderBody()
        </div>
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
