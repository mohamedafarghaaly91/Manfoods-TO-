@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpCtx
@{
    var session = HttpCtx.HttpContext?.Session;
    var userEmail = session?.GetString("Email") ?? "";
    var userRole  = session?.GetString("Role")  ?? "";
    var currentPath = HttpCtx.HttpContext?.Request.Path.Value ?? "";
    bool IsActive(string seg) => currentPath.Contains(seg, StringComparison.OrdinalIgnoreCase);
    var initials = string.IsNullOrEmpty(userEmail) ? "A" : userEmail.Substring(0,1).ToUpper();
    bool isFullAdmin = userRole == "Admin_Full";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Admin | Manfoods" : "Admin | Manfoods McDonald's")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>
<body>
<div class="app-wrapper">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo-row">
                <img src="/images/mclogo.png" alt="Logo" class="brand-logo-img"/>
                <div class="brand-texts">
                    <span class="brand-name-main">Manfoods</span>
                    <span class="brand-name-sub">Admin Portal</span>
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Analytics</div>
            <a href="/admin/dashboard/analytics" class="nav-item @(IsActive("Analytics") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-bar-chart-line-fill"></i></span>
                    <span class="nav-item-label">Global Analytics</span>
                </span>
            </a>
            <a href="/admin/dashboard/turnover" class="nav-item @(IsActive("Turnover") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-pie-chart-fill"></i></span>
                    <span class="nav-item-label">Turnover Analysis</span>
                </span>
            </a>

            <div class="nav-section-label">Management</div>
            <a href="/admin/dashboard/uploads" class="nav-item @(IsActive("Uploads") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-cloud-upload-fill"></i></span>
                    <span class="nav-item-label">Data Management</span>
                </span>
            </a>
            <a href="/admin/dashboard/reports" class="nav-item @(IsActive("Reports") ? "active" : "")">
                <span class="nav-item-inner">
                    <span class="nav-icon-wrap"><i class="bi bi-file-earmark-bar-graph-fill"></i></span>
                    <span class="nav-item-label">Reports</span>
                </span>
            </a>

            @if (isFullAdmin)
            {
                <div class="nav-section-label">System</div>
                <a href="/admin/dashboard/users" class="nav-item @(IsActive("Users") ? "active" : "")">
                    <span class="nav-item-inner">
                        <span class="nav-icon-wrap"><i class="bi bi-people-fill"></i></span>
                        <span class="nav-item-label">Users</span>
                        <span class="nav-item-badge">Admin</span>
                    </span>
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-footer-inner">
                <div class="user-avatar">@initials</div>
                <div class="user-details">
                    <div class="user-email">@userEmail</div>
                    <div class="user-role-badge">
                        <i class="bi bi-shield-fill-check" style="font-size:9px;"></i>
                        @userRole.Replace("_"," ")
                    </div>
                </div>
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" title="Sign Out"><i class="bi bi-box-arrow-right"></i></button>
                </form>
            </div>
        </div>
    </aside>

    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert-banner alert-success-banner">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-banner alert-error-banner">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            </div>
        }
        <div class="page-content">
            @RenderBody()
        </div>
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<!-- ═══════════════════════════════════════════════════
     AI CHAT WIDGET
═══════════════════════════════════════════════════ -->
<style>
    #ai-fab {
        position: fixed; bottom: 28px; right: 28px; z-index: 1050;
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, #c8102e, #da291c);
        border: none; box-shadow: 0 4px 18px rgba(200,16,46,.45);
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: transform .2s, box-shadow .2s;
    }
    #ai-fab:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(200,16,46,.55); }
    #ai-fab svg { width: 26px; height: 26px; fill: #fff; }
    #ai-fab .ai-fab-badge {
        position: absolute; top: -2px; right: -2px;
        width: 14px; height: 14px; border-radius: 50%;
        background: #FFC72C; border: 2px solid #fff;
        display: none;
    }
    #ai-fab .ai-fab-badge.has-msg { display: block; }

    #ai-panel {
        position: fixed; bottom: 96px; right: 28px; z-index: 1049;
        width: 370px; height: 520px;
        background: #fff; border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,.18);
        display: none; flex-direction: column; overflow: hidden;
        border: 1px solid #f0f0f0;
        animation: aiSlideUp .22s ease;
    }
    #ai-panel.open { display: flex; }
    @@keyframes aiSlideUp {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .ai-header {
        background: linear-gradient(135deg, #c8102e, #da291c);
        color: #fff; padding: 14px 16px;
        display: flex; align-items: center; gap: 10px;
    }
    .ai-header-icon {
        width: 34px; height: 34px; background: rgba(255,255,255,.18);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 16px; flex-shrink: 0;
    }
    .ai-header-texts { flex: 1; }
    .ai-header-title { font-size: 14px; font-weight: 700; line-height: 1.2; }
    .ai-header-sub { font-size: 11px; opacity: .8; }
    .ai-close-btn {
        background: none; border: none; color: #fff; opacity: .8;
        font-size: 20px; line-height: 1; cursor: pointer; padding: 0;
        transition: opacity .15s;
    }
    .ai-close-btn:hover { opacity: 1; }

    .ai-messages {
        flex: 1; overflow-y: auto; padding: 14px;
        display: flex; flex-direction: column; gap: 10px;
        background: #fafafa;
    }
    .ai-messages::-webkit-scrollbar { width: 4px; }
    .ai-messages::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }

    .ai-bubble {
        max-width: 88%; padding: 10px 13px;
        border-radius: 14px; font-size: 13.5px; line-height: 1.55;
        word-break: break-word;
    }
    .ai-bubble.bot {
        background: #fff; border: 1px solid #ececec;
        border-bottom-left-radius: 4px; align-self: flex-start;
        color: #222;
    }
    .ai-bubble.user {
        background: linear-gradient(135deg, #c8102e, #da291c);
        color: #fff; border-bottom-right-radius: 4px;
        align-self: flex-end;
    }
    .ai-bubble.loading { background: #fff; border: 1px solid #ececec; align-self: flex-start; }
    .ai-dots span {
        display: inline-block; width: 7px; height: 7px;
        background: #bbb; border-radius: 50%; margin: 0 2px;
        animation: aiDot 1.2s infinite;
    }
    .ai-dots span:nth-child(2) { animation-delay: .2s; }
    .ai-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes aiDot {
        0%,80%,100% { transform: scale(.7); opacity:.5; }
        40%          { transform: scale(1);  opacity:1; }
    }

    .ai-footer {
        padding: 10px 12px; border-top: 1px solid #f0f0f0;
        background: #fff; display: flex; gap: 8px; align-items: flex-end;
    }
    #ai-input {
        flex: 1; border: 1px solid #e0e0e0; border-radius: 10px;
        padding: 9px 12px; font-size: 13.5px; resize: none;
        outline: none; max-height: 90px; line-height: 1.4;
        font-family: inherit; transition: border-color .2s;
    }
    #ai-input:focus { border-color: #c8102e; }
    #ai-send-btn {
        width: 38px; height: 38px; border-radius: 10px; border: none; flex-shrink: 0;
        background: linear-gradient(135deg, #c8102e, #da291c);
        color: #fff; cursor: pointer; display: flex;
        align-items: center; justify-content: center;
        transition: opacity .2s; font-size: 15px;
    }
    #ai-send-btn:disabled { opacity: .45; cursor: default; }
</style>

<button id="ai-fab" title="AI Assistant">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.38-1 1.73V7h2a7 7 0 0 1 7 7v1a7 7 0 0 1-7 7H9a7 7 0 0 1-7-7v-1a7 7 0 0 1 7-7h2V5.73A2 2 0 0 1 10 4a2 2 0 0 1 2-2zm-3 9a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm6 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
    </svg>
    <span class="ai-fab-badge" id="ai-badge"></span>
</button>

<div id="ai-panel">
    <div class="ai-header">
        <div class="ai-header-icon">🤖</div>
        <div class="ai-header-texts">
            <div class="ai-header-title">Manfoods AI Assistant</div>
            <div class="ai-header-sub">مساعد تحليل بيانات الموظفين</div>
        </div>
        <button class="ai-close-btn" id="ai-close-btn" title="إغلاق">×</button>
    </div>
    <div class="ai-messages" id="ai-messages">
        <div class="ai-bubble bot">
            مرحبًا! 👋 أنا مساعدك الذكي لتحليل بيانات الموظفين.<br><br>
            يمكنني مساعدتك في تحليل معدلات الـ Turnover، الـ Headcount، الاستقالات، وتقديم توصيات. اسألني ما تريد!
        </div>
    </div>
    <div class="ai-footer">
        <textarea id="ai-input" rows="1" placeholder="اكتب سؤالك هنا..."></textarea>
        <button id="ai-send-btn" title="إرسال">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

<script>
(function () {
    const fab       = document.getElementById('ai-fab');
    const panel     = document.getElementById('ai-panel');
    const closeBtn  = document.getElementById('ai-close-btn');
    const messages  = document.getElementById('ai-messages');
    const input     = document.getElementById('ai-input');
    const sendBtn   = document.getElementById('ai-send-btn');
    const badge     = document.getElementById('ai-badge');

    let isOpen = false;
    let unread = false;

    fab.addEventListener('click', () => {
        isOpen = !isOpen;
        panel.classList.toggle('open', isOpen);
        if (isOpen) { badge.classList.remove('has-msg'); unread = false; input.focus(); scrollBottom(); }
    });

    closeBtn.addEventListener('click', () => {
        isOpen = false;
        panel.classList.remove('open');
    });

    input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
    input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 90) + 'px';
    });

    sendBtn.addEventListener('click', sendMessage);

    function scrollBottom() {
        setTimeout(() => { messages.scrollTop = messages.scrollHeight; }, 50);
    }

    function addBubble(text, type) {
        const d = document.createElement('div');
        d.className = 'ai-bubble ' + type;
        if (type === 'loading') {
            d.innerHTML = '<div class="ai-dots"><span></span><span></span><span></span></div>';
        } else {
            d.innerHTML = text.replace(/\n/g, '<br>');
        }
        messages.appendChild(d);
        scrollBottom();
        return d;
    }

    function getPageContext() {
        const params = new URLSearchParams(window.location.search);
        return {
            month: params.get('month') ? parseInt(params.get('month')) : null,
            year:  params.get('year')  ? parseInt(params.get('year'))  : null,
            store: params.get('store') || null
        };
    }

    async function sendMessage() {
        const q = input.value.trim();
        if (!q || sendBtn.disabled) return;

        addBubble(q, 'user');
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;

        const loading = addBubble('', 'loading');
        const ctx = getPageContext();

        try {
            const res = await fetch('/api/dashboard/ai-chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: q, month: ctx.month, year: ctx.year, store: ctx.store })
            });
            const data = await res.json();
            loading.remove();
            addBubble(data.answer || 'لم يتم الحصول على إجابة.', 'bot');
        } catch {
            loading.remove();
            addBubble('تعذر الاتصال بالخادم. حاول مرة أخرى.', 'bot');
        }

        sendBtn.disabled = false;
        input.focus();

        if (!isOpen) { badge.classList.add('has-msg'); unread = true; }
    }
})();
</script>
</body>
</html>
