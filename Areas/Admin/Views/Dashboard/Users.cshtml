@model List<MvcApp.Models.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div><h1 class="page-title">Users</h1><p class="page-subtitle">Manage system access and roles</p></div>
    <a href="/admin/dashboard/createuser" class="btn btn-primary"><i class="bi bi-person-plus me-2"></i>New User</a>
</div>

<div class="card-dark">
    @if (!Model.Any())
    {
        <div class="empty-state"><i class="bi bi-people"></i><p>No users yet</p></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark-custom">
                <thead><tr><th>Email</th><th>Role</th><th>Assigned Name</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-medium">@user.Email</td>
                            <td><span class="role-badge role-@user.Role.ToLower().Replace("_","-")">@user.Role.Replace("_"," ")</span></td>
                            <td class="text-muted-custom">@(user.AssignedName ?? "—")</td>
                            <td class="text-muted-custom small">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <a href="/admin/dashboard/edituser/@user.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                                <form asp-area="Admin" asp-controller="Dashboard" asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Delete user @user.Email?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id"/>
                                    <button type="submit" class="btn btn-sm btn-danger-outline"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
